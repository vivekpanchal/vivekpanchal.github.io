---
const contacts = [
  { icon: 'fas fa-envelope', label: 'Email', value: 'vivekpanchal07@gmail.com', href: 'mailto:vivekpanchal07@gmail.com' },
  { icon: 'fab fa-linkedin-in', label: 'LinkedIn', value: 'linkedin.com/in/vivekpanchal07', href: 'https://linkedin.com/in/vivekpanchal07' },
  { icon: 'fab fa-github', label: 'GitHub', value: 'github.com/vivekpanchal', href: 'https://github.com/vivekpanchal' },
  { icon: 'fas fa-map-marker-alt', label: 'Location', value: 'New Delhi, India', href: null },
];
---

<section class="contact section" id="contact">
  <div class="container">
    <header class="section-header">
      <h2 class="section-title">Get In Touch</h2>
      <div class="divider"></div>
      <p class="section-subtitle">Open to opportunities and collaborations</p>
    </header>

    <div class="contact-inner">
      <div class="contact-text">
        <h3>Let's work together!</h3>
        <p>
          I'm currently open to new opportunities. Whether you have a project in mind,
          a role you think I'd be a great fit for, or just want to say hello —
          my inbox is always open.
        </p>
        <a href="mailto:vivekpanchal07@gmail.com" class="btn btn-primary">
          <i class="fas fa-paper-plane" aria-hidden="true"></i> Say Hello
        </a>
      </div>

      <ul class="contact-cards" aria-label="Contact information">
        {contacts.map(({ icon, label, value, href }) => (
          <li>
            <div class="contact-card card">
              <span class="contact-icon">
                <i class={icon} aria-hidden="true"></i>
              </span>
              <div class="contact-info">
                <span class="contact-label">{label}</span>
                {href ? (
                  <a href={href} class="contact-value" target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}>
                    {value}
                  </a>
                ) : (
                  <span class="contact-value">{value}</span>
                )}
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .contact-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .contact-text h3 {
    font-size: 1.6rem;
    margin-bottom: 1rem;
    font-family: var(--font-heading);
  }

  .contact-text p {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 1.75rem;
  }

  .contact-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
  }

  .contact-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(108, 99, 255, 0.1);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .contact-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    font-weight: 600;
  }

  .contact-value {
    font-size: 0.92rem;
    color: var(--text-primary);
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  a.contact-value:hover {
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .contact-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
