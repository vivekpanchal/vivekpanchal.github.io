---
const experiences = [
  {
    company: 'Dario',
    role: 'SDE-2 — Android',
    period: 'Nov 2024 – Present',
    location: 'New Delhi, India',
    description: 'Leading Android development at Dario, a digital health platform. Architecting scalable features using MVVM + Clean Architecture, driving performance improvements, and collaborating cross-functionally on product delivery.',
    highlights: ['Kotlin', 'MVVM', 'Clean Architecture', 'Hilt DI', 'Jetpack'],
    color: '#6c63ff',
    current: true,
  },
  {
    company: 'Trustt',
    role: 'SDE-2 — Android',
    period: 'Jun 2023 – Nov 2024',
    location: 'Bangalore, India · On-site',
    description: 'Promoted to SDE-2 at Trustt. Led key Android feature development, improved app architecture, mentored junior engineers, and drove adoption of Kotlin Coroutines and modern Jetpack components.',
    highlights: ['Android', 'Kotlin', 'Algorithms', 'Jetpack', 'Coroutines'],
    color: '#a855f7',
  },
  {
    company: 'Trustt',
    role: 'SDE — Android',
    period: 'Jun 2022 – May 2023',
    location: 'Bangalore, India · Hybrid',
    description: 'Joined Trustt as an SDE, working on core Android product features. Implemented complex UI flows, integrated APIs, and optimised app performance across the codebase.',
    highlights: ['Android', 'Kotlin', 'Algorithms', 'REST APIs', 'MVVM'],
    color: '#8b5cf6',
  },
  {
    company: 'StudyIQ Education',
    role: 'Senior Android Developer',
    period: 'Jul 2020 – Feb 2022',
    location: 'Delhi, India · On-site',
    description: 'Developed and maintained the StudyIQ Android app used by millions of students across India. Built live video streaming, offline content downloads, and performance-critical features.',
    highlights: ['Android', 'Android Development', 'ExoPlayer', 'Live Streaming', 'Room DB'],
    color: '#f59e0b',
  },
  {
    company: 'Broad Strokes Ventures',
    role: 'Senior Android Developer',
    period: 'Aug 2019 – Apr 2020',
    location: 'Delhi, India · On-site',
    description: 'Built Android applications end-to-end for Broad Strokes Ventures. Responsible for architecture decisions, SDK integrations, and delivering production-ready mobile features.',
    highlights: ['Android Development', 'Android SDK', 'Java'],
    color: '#ec4899',
  },
  {
    company: 'Stackfusion Private Limited',
    role: 'Android Developer',
    period: 'Jul 2018 – Aug 2019',
    location: 'Gurugram, Haryana · On-site',
    description: 'Started career as an Android Developer at Stackfusion, building and shipping Android applications. Gained hands-on experience with the full mobile development lifecycle.',
    highlights: ['Android', 'Android Development', 'Java', 'REST APIs'],
    color: '#06b6d4',
  },
];
---

<section class="experience section section-alt" id="experience">
  <div class="container">
    <header class="section-header reveal">
      <p class="section-num">02 / Experience</p>
      <h2 class="section-title">Experience</h2>
      <div class="divider"></div>
      <p class="section-subtitle">Where I've worked and what I've built</p>
    </header>

    <div class="timeline">
      {experiences.map((exp, i) => (
        <article class="timeline-item reveal" style={`--accent: ${exp.color}; transition-delay: ${i * 0.07}s`}>
          <div class="timeline-dot"></div>
          <div class="timeline-card card">
            <div class="exp-header">
              <div class="exp-meta">
                <h3 class="exp-role">
                  {exp.role}
                  {exp.current && <span class="current-badge">Current</span>}
                </h3>
                <p class="exp-company">{exp.company}</p>
              </div>
              <div class="exp-period">
                <span class="period-badge">
                  <i class="far fa-calendar-alt" aria-hidden="true"></i>
                  {exp.period}
                </span>
                <span class="period-badge">
                  <i class="fas fa-map-marker-alt" aria-hidden="true"></i>
                  {exp.location}
                </span>
              </div>
            </div>
            <p class="exp-desc">{exp.description}</p>
            <ul class="exp-highlights">
              {exp.highlights.map(h => (
                <li><span class="tag">{h}</span></li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline {
    position: relative;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, var(--color-primary), var(--color-secondary));
    border-radius: 2px;
  }

  .timeline-item {
    position: relative;
    margin-bottom: 2rem;
  }

  .timeline-item:last-child {
    margin-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    left: -2rem;
    top: 1.5rem;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--accent, var(--color-primary));
    border: 3px solid var(--bg-body);
    box-shadow: 0 0 0 2px var(--accent, var(--color-primary));
    z-index: 1;
  }

  .timeline-card {
    padding: 1.75rem;
    border-left: 3px solid var(--accent, var(--color-primary));
  }

  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
  }

  .exp-role {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .current-badge {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-pill);
    background: rgba(34, 197, 94, 0.15);
    color: #22c55e;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }

  .exp-company {
    font-size: 1rem;
    color: var(--accent, var(--color-primary));
    font-weight: 600;
    margin-top: 0.15rem;
  }

  .exp-period {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    align-items: flex-end;
  }

  .period-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .exp-desc {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .exp-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  @media (max-width: 600px) {
    .exp-header {
      flex-direction: column;
    }

    .exp-period {
      align-items: flex-start;
    }
  }
</style>
