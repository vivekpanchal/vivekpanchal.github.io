---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
  tags?: string[];
}

const {
  title = 'Vivek Panchal — Senior Android Developer | SDE-2 at Dario',
  description = 'Vivek Panchal — Senior Android Developer with 7+ years of experience. SDE-2 at Dario. Expert in Kotlin, Java, MVVM, Jetpack, Dagger2, Coroutines. Previously at Trustt & StudyIQ. Based in New Delhi, India.',
  image = '/og-image.png',
  url = Astro.url.href,
  type = 'website',
  publishedDate,
  tags = [],
} = Astro.props;

const siteName = 'Vivek Panchal';
const twitterHandle = '@vivekpanchal64';
const canonicalUrl = url;
---

<!-- Primary Meta -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="description" content={description} />
<meta name="author" content="Vivek Panchal" />
<meta name="keywords" content={[
  'Vivek Panchal', 'Android Developer', 'Senior Android Developer', 'SDE-2',
  'Kotlin', 'Java', 'MVVM', 'Clean Architecture', 'Jetpack Compose',
  'Dagger2', 'Hilt', 'Coroutines', 'RxJava', 'Retrofit', 'Room DB',
  'Dario', 'Trustt', 'StudyIQ', 'New Delhi', 'India', 'Software Engineer',
  'Mobile Developer', 'Android SDK', 'Firebase', 'GitHub',
  ...tags
].join(', ')} />
<meta name="robots" content="index, follow" />
<meta name="theme-color" content="#6c63ff" />
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={new URL(image, Astro.site)} />
<meta property="og:image:alt" content={title} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="en_US" />
{publishedDate && <meta property="article:published_time" content={publishedDate} />}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={twitterHandle} />
<meta name="twitter:creator" content={twitterHandle} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(image, Astro.site)} />

<!-- Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(type === 'article' ? {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "author": {
    "@type": "Person",
    "name": "Vivek Panchal",
    "url": "https://vivekpanchal.dev"
  },
  "datePublished": publishedDate,
  "image": new URL(image, Astro.site),
  "url": canonicalUrl,
} : {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Vivek Panchal",
  "url": "https://vivekpanchal.dev",
  "sameAs": [
    "https://github.com/vivekpanchal",
    "https://www.linkedin.com/in/vivekpanchal-developer/",
    "https://medium.com/@vivekpanchal",
    "https://x.com/vivekpanchal64",
    "https://stackoverflow.com/users/7685845/vivek-panchal"
  ],
  "jobTitle": "SDE-2",
  "worksFor": {
    "@type": "Organization",
    "name": "Dario"
  },
  "knowsAbout": ["Android Development", "Kotlin", "Java", "MVVM", "Clean Architecture", "Jetpack", "Dagger2", "Hilt", "Coroutines", "RxJava", "Firebase", "Room DB"],
  "hasOccupation": {
    "@type": "Occupation",
    "name": "Senior Android Developer",
    "occupationLocation": {
      "@type": "City",
      "name": "New Delhi"
    },
    "experienceRequirements": "7+ years"
  },
  "description": description,
  "image": new URL(image, Astro.site),
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "New Delhi",
    "addressCountry": "IN"
  }
})} />
