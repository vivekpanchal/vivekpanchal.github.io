---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const wordCount = post.body?.split(' ').length ?? 0;
const readTime = Math.ceil(wordCount / 200);
---

<Layout
  title={`${post.data.title} — Vivek Panchal`}
  description={post.data.description}
  image={post.data.heroImage}
  type="article"
  publishedDate={post.data.pubDate.toISOString()}
  tags={post.data.tags}
>
  <article class="blog-post">
    <div class="container">
      <!-- Nav -->
      <nav class="post-nav" aria-label="Breadcrumb">
        <a href="/" class="nav-link">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/blog" class="nav-link">Blog</a>
        <span aria-hidden="true">/</span>
        <span class="nav-current" aria-current="page">{post.data.title}</span>
      </nav>

      <!-- Header -->
      <header class="post-header">
        <ul class="post-tags" aria-label="Tags">
          {post.data.tags.map(tag => <li><span class="tag">{tag}</span></li>)}
        </ul>
        <h1 class="post-title">{post.data.title}</h1>
        <p class="post-desc">{post.data.description}</p>
        <div class="post-meta">
          <div class="author">
            <img
              src="https://avatars.githubusercontent.com/u/22134822?v=4"
              alt="Vivek Panchal"
              width="36"
              height="36"
              class="author-avatar"
            />
            <div>
              <span class="author-name">{post.data.author}</span>
              <div class="post-dates">
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
                {post.data.updatedDate && (
                  <span class="updated">
                    · Updated {formatDate(post.data.updatedDate)}
                  </span>
                )}
              </div>
            </div>
          </div>
          <span class="read-time">
            <i class="far fa-clock" aria-hidden="true"></i>
            {readTime} min read
          </span>
        </div>
      </header>

      <!-- Hero image -->
      {post.data.heroImage && (
        <div class="post-hero">
          <img src={post.data.heroImage} alt={post.data.title} loading="lazy" />
        </div>
      )}

      <!-- Body -->
      <div class="post-body prose">
        <Content />
      </div>

      <!-- Footer -->
      <footer class="post-footer">
        <div class="share-section">
          <p>Share this article:</p>
          <div class="share-links">
            <a
              href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-btn twitter"
              aria-label="Share on Twitter"
            >
              <i class="fab fa-twitter" aria-hidden="true"></i> Tweet
            </a>
            <a
              href={`https://linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.href)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="share-btn linkedin"
              aria-label="Share on LinkedIn"
            >
              <i class="fab fa-linkedin-in" aria-hidden="true"></i> Share
            </a>
          </div>
        </div>
        <a href="/blog" class="back-btn">
          <i class="fas fa-arrow-left" aria-hidden="true"></i> All Posts
        </a>
      </footer>
    </div>
  </article>
</Layout>

<!-- Font Awesome -->
<link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
  crossorigin="anonymous"
  referrerpolicy="no-referrer"
/>

<style>
  .blog-post {
    padding: 2.5rem 0 6rem;
  }

  .post-nav {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .nav-link {
    color: var(--text-muted);
    transition: color var(--transition);
  }

  .nav-link:hover {
    color: var(--color-primary);
  }

  .nav-current {
    color: var(--text-secondary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 300px;
  }

  .post-header {
    max-width: 800px;
    margin: 0 auto 2.5rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .post-desc {
    font-size: 1.15rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding: 1rem 0;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
  }

  .author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .author-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 2px solid var(--color-primary);
  }

  .author-name {
    display: block;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text-primary);
  }

  .post-dates {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .updated {
    color: var(--text-muted);
  }

  .read-time {
    font-size: 0.82rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .post-hero {
    max-width: 800px;
    margin: 0 auto 2.5rem;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .post-hero img {
    width: 100%;
    height: 400px;
    object-fit: cover;
  }

  /* Prose styles */
  .prose {
    max-width: 800px;
    margin: 0 auto;
    font-size: 1.05rem;
    line-height: 1.85;
    color: var(--text-secondary);
  }

  .prose :global(h2) {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border-color);
  }

  .prose :global(h3) {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 2rem 0 0.75rem;
  }

  .prose :global(h4) {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 1.5rem 0 0.5rem;
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color var(--transition);
  }

  .prose :global(a:hover) {
    text-decoration-color: var(--color-primary);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 1rem 0 1.25rem 1.5rem;
    list-style: unset;
  }

  .prose :global(ol) {
    list-style: decimal;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .prose :global(strong) {
    color: var(--text-primary);
    font-weight: 700;
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--color-primary);
    padding: 0.75rem 1.25rem;
    margin: 1.5rem 0;
    background: rgba(108, 99, 255, 0.05);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .prose :global(code) {
    font-family: 'Fira Code', 'Cascadia Code', monospace;
    font-size: 0.88em;
    background: var(--bg-code);
    padding: 0.15em 0.45em;
    border-radius: 4px;
    color: var(--color-primary);
  }

  .prose :global(pre) {
    background: #1e1e3a;
    border-radius: var(--radius-md);
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 1.5rem 0;
    box-shadow: var(--shadow-md);
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    color: #e2e2ff;
    font-size: 0.88rem;
  }

  .prose :global(hr) {
    border: none;
    border-top: 2px solid var(--border-color);
    margin: 2.5rem 0;
  }

  .prose :global(img) {
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    margin: 1.5rem auto;
  }

  /* Post footer */
  .post-footer {
    max-width: 800px;
    margin: 3rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .share-section {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .share-section p {
    font-size: 0.9rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .share-links {
    display: flex;
    gap: 0.5rem;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-pill);
    font-size: 0.82rem;
    font-weight: 600;
    transition: all var(--transition);
  }

  .share-btn.twitter {
    background: rgba(29, 161, 242, 0.1);
    color: #1da1f2;
    border: 1px solid rgba(29, 161, 242, 0.2);
  }

  .share-btn.twitter:hover {
    background: #1da1f2;
    color: #fff;
  }

  .share-btn.linkedin {
    background: rgba(0, 119, 181, 0.1);
    color: #0077b5;
    border: 1px solid rgba(0, 119, 181, 0.2);
  }

  .share-btn.linkedin:hover {
    background: #0077b5;
    color: #fff;
  }

  .back-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-muted);
    transition: color var(--transition);
  }

  .back-btn:hover {
    color: var(--color-primary);
  }
</style>
